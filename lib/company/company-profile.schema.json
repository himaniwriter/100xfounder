{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://100xfounder.com/schemas/company-profile.schema.json",
  "title": "CompanyProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "name",
    "one_liner",
    "description",
    "tags",
    "stats",
    "founders",
    "job_openings"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "description": "Unique URL-safe identifier for /company/[slug]",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 120
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "one_liner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "description": {
      "type": "string",
      "description": "Long-form markdown content for the About section",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 60
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "founded",
        "team_size",
        "location",
        "website"
      ],
      "properties": {
        "founded": {
          "type": "integer",
          "minimum": 1800,
          "maximum": 2100
        },
        "team_size": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          ]
        },
        "location": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "website": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "founders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "role",
          "image_url",
          "linkedin"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "image_url": {
            "type": "string",
            "format": "uri"
          },
          "linkedin": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "job_openings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "url"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  }
}

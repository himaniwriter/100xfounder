generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FounderStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum UserRole {
  ADMIN
  MEMBER
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FundingStage {
  BOOTSTRAPPED
  PRE_SEED
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
  SERIES_D
  SERIES_E
  SERIES_F
  IPO
  ACQUIRED
}

enum PostStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  avatar    String?
  passwordHash String?
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  founderProfile    FounderProfile?
  endorsementsGiven Endorsement[]  @relation("EndorsementsGiven")
  claims            ClaimRequest[]
  connectors        AggregatorConnection[] @relation("ConnectorCreator")
  claimedDirectoryEntries FounderDirectoryEntry[] @relation("DirectoryEntryClaimant")

  @@index([createdAt])
  @@index([role])
  @@map("users")
}

model FounderProfile {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @unique @db.Uuid
  bio         String?
  location    String?
  linkedinUrl String?
  twitterUrl  String?
  website     String?
  slug        String       @unique
  status      FounderStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  startups     FounderStartup[]
  endorsements Endorsement[]    @relation("FounderEndorsements")

  @@index([status])
  @@index([location])
  @@index([status, createdAt])
  @@map("founder_profiles")
}

model Startup {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  oneLiner     String?
  website      String?
  fundingStage FundingStage @default(BOOTSTRAPPED)
  totalRaised  Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  founders FounderStartup[]

  @@index([name])
  @@index([fundingStage])
  @@index([totalRaised])
  @@index([fundingStage, totalRaised])
  @@map("startups")
}

model FounderStartup {
  founderId String   @db.Uuid
  startupId String   @db.Uuid
  roleTitle String?
  isPrimary Boolean  @default(false)
  joinedAt  DateTime @default(now())

  founder FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)
  startup Startup        @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@id([founderId, startupId])
  @@index([startupId])
  @@index([founderId, isPrimary])
  @@map("founder_startups")
}

model Endorsement {
  id         String   @id @default(uuid()) @db.Uuid
  endorserId String   @db.Uuid
  founderId  String   @db.Uuid
  skill      String
  note       String?
  createdAt  DateTime @default(now())

  endorser User          @relation("EndorsementsGiven", fields: [endorserId], references: [id], onDelete: Cascade)
  founder  FounderProfile @relation("FounderEndorsements", fields: [founderId], references: [id], onDelete: Cascade)

  @@unique([endorserId, founderId, skill])
  @@index([founderId])
  @@index([endorserId])
  @@index([skill])
  @@index([founderId, skill])
  @@index([createdAt])
  @@map("endorsements")
}

model FounderDirectoryEntry {
  id             String   @id @default(cuid())
  slug           String   @unique
  founderName    String
  companyName    String
  foundedYear    Int?
  headquarters   String?
  industry       String
  stage          String
  productSummary String
  fundingInfo    String?
  sourceUrl      String?
  ycProfileUrl   String?
  websiteUrl     String?
  employeeCount  String?
  techStack      String[]
  recentNews     String[]
  linkedinUrl    String?
  twitterUrl     String?
  verified       Boolean  @default(true)
  avatarUrl      String?
  claimedByUserId String? @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  claimedByUser User? @relation("DirectoryEntryClaimant", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  claimRequests ClaimRequest[]

  @@index([companyName])
  @@index([industry])
  @@index([headquarters])
  @@index([stage])
  @@index([claimedByUserId])
  @@map("founder_directory_entries")
}

model ClaimRequest {
  id          String      @id @default(cuid())
  userId      String      @db.Uuid
  founderEntryId String
  message     String?
  status      ClaimStatus @default(PENDING)
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  founderEntry FounderDirectoryEntry @relation(fields: [founderEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, founderEntryId])
  @@index([status])
  @@index([createdAt])
  @@map("claim_requests")
}

model AggregatorConnection {
  id           String   @id @default(cuid())
  name         String
  provider     String
  endpoint     String
  authHeader   String?
  authValue    String?
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  createdById  String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy User @relation("ConnectorCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([isActive])
  @@index([createdById])
  @@map("aggregator_connections")
}

model Post {
  id             String     @id @default(uuid()) @db.Uuid
  title          String
  content        String
  slug           String     @unique
  featureImage   String     @map("feature_image")
  imageCredit    String?    @map("image_credit")
  seoTitle       String     @map("seo_title")
  seoDescription String     @map("seo_description")
  wordCount      Int        @map("word_count")
  status         PostStatus @default(DRAFT)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@index([status, createdAt(sort: Desc)])
  @@map("posts")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FounderStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum UserRole {
  ADMIN
  MEMBER
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FundingStage {
  BOOTSTRAPPED
  PRE_SEED
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
  SERIES_D
  SERIES_E
  SERIES_F
  IPO
  ACQUIRED
}

enum PostStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
}

enum FeaturedPlan {
  STARTER  @map("starter")
  GROWTH   @map("growth")
  PRIORITY @map("priority")

  @@map("featured_plan")
}

enum FeaturedRequestStatus {
  NEW       @map("new")
  IN_REVIEW @map("in_review")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  PUBLISHED @map("published")

  @@map("featured_request_status")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  avatar    String?
  passwordHash String?
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  founderProfile    FounderProfile?
  endorsementsGiven Endorsement[]  @relation("EndorsementsGiven")
  claims            ClaimRequest[]
  connectors        AggregatorConnection[] @relation("ConnectorCreator")
  claimedDirectoryEntries FounderDirectoryEntry[] @relation("DirectoryEntryClaimant")

  @@index([createdAt])
  @@index([role])
  @@map("users")
}

model FounderProfile {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @unique @db.Uuid
  bio         String?
  location    String?
  linkedinUrl String?
  twitterUrl  String?
  website     String?
  slug        String       @unique
  status      FounderStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  startups     FounderStartup[]
  endorsements Endorsement[]    @relation("FounderEndorsements")

  @@index([status])
  @@index([location])
  @@index([status, createdAt])
  @@map("founder_profiles")
}

model Startup {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  oneLiner     String?
  website      String?
  fundingStage FundingStage @default(BOOTSTRAPPED)
  totalRaised  Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  founders FounderStartup[]

  @@index([name])
  @@index([fundingStage])
  @@index([totalRaised])
  @@index([fundingStage, totalRaised])
  @@map("startups")
}

model FounderStartup {
  founderId String   @db.Uuid
  startupId String   @db.Uuid
  roleTitle String?
  isPrimary Boolean  @default(false)
  joinedAt  DateTime @default(now())

  founder FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)
  startup Startup        @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@id([founderId, startupId])
  @@index([startupId])
  @@index([founderId, isPrimary])
  @@map("founder_startups")
}

model Endorsement {
  id         String   @id @default(uuid()) @db.Uuid
  endorserId String   @db.Uuid
  founderId  String   @db.Uuid
  skill      String
  note       String?
  createdAt  DateTime @default(now())

  endorser User          @relation("EndorsementsGiven", fields: [endorserId], references: [id], onDelete: Cascade)
  founder  FounderProfile @relation("FounderEndorsements", fields: [founderId], references: [id], onDelete: Cascade)

  @@unique([endorserId, founderId, skill])
  @@index([founderId])
  @@index([endorserId])
  @@index([skill])
  @@index([founderId, skill])
  @@index([createdAt])
  @@map("endorsements")
}

model FounderDirectoryEntry {
  id             String   @id @default(cuid())
  slug           String   @unique
  founderName    String
  companyName    String
  foundedYear    Int?
  headquarters   String?
  industry       String
  stage          String
  productSummary String
  fundingInfo    String?
  sourceUrl      String?
  ycProfileUrl   String?
  websiteUrl     String?
  employeeCount  String?
  techStack      String[]
  recentNews     String[]
  linkedinUrl    String?
  twitterUrl     String?
  verified       Boolean  @default(true)
  avatarUrl      String?
  claimedByUserId String? @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  claimedByUser User? @relation("DirectoryEntryClaimant", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  claimRequests ClaimRequest[]

  @@index([companyName])
  @@index([industry])
  @@index([headquarters])
  @@index([stage])
  @@index([claimedByUserId])
  @@map("founder_directory_entries")
}

model ClaimRequest {
  id          String      @id @default(cuid())
  userId      String      @db.Uuid
  founderEntryId String
  message     String?
  status      ClaimStatus @default(PENDING)
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  founderEntry FounderDirectoryEntry @relation(fields: [founderEntryId], references: [id], onDelete: Cascade)

  @@unique([userId, founderEntryId])
  @@index([status])
  @@index([createdAt])
  @@map("claim_requests")
}

model AggregatorConnection {
  id           String   @id @default(cuid())
  name         String
  provider     String
  endpoint     String
  authHeader   String?
  authValue    String?
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  createdById  String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy User @relation("ConnectorCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([isActive])
  @@index([createdById])
  @@map("aggregator_connections")
}

model Post {
  id             String     @id @default(uuid()) @db.Uuid
  title          String
  subtitle       String?
  content        String
  slug           String     @unique
  articleType    String     @default("analysis") @map("article_type")
  topicSlug      String?    @map("topic_slug")
  featureImage   String     @map("feature_image")
  imageCredit    String?    @map("image_credit")
  author         String     @default("100Xfounder Research") @map("author")
  authorId       String?    @db.Uuid @map("author_id")
  canonicalUrl   String?    @map("canonical_url")
  sourceUrlsJson Json?      @map("source_urls_json")
  factCheckStatus String    @default("pending_review") @map("fact_check_status")
  correctionNote String?    @map("correction_note")
  discoverReady  Boolean    @default(false) @map("discover_ready")
  socialImageUrl String?    @map("social_image_url")
  seoTitle       String     @map("seo_title")
  seoDescription String     @map("seo_description")
  wordCount      Int        @map("word_count")
  status         PostStatus @default(DRAFT)
  publishedAt    DateTime?  @map("published_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  authorProfile  Author?    @relation("AuthorPosts", fields: [authorId], references: [id], onDelete: SetNull)
  updates        PostUpdate[]
  citations      PostCitation[]

  @@index([status, createdAt(sort: Desc)])
  @@index([publishedAt(sort: Desc), status])
  @@index([topicSlug, publishedAt(sort: Desc)])
  @@index([authorId])
  @@map("posts")
}

model Author {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  bio       String?
  role      String?
  avatarUrl String?  @map("avatar_url")
  sameAsJson Json?   @map("same_as_json")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  posts     Post[]   @relation("AuthorPosts")

  @@index([isActive])
  @@map("authors")
}

model PostUpdate {
  id         String   @id @default(uuid()) @db.Uuid
  postId     String   @db.Uuid @map("post_id")
  changeType String   @map("change_type")
  note       String?
  changedBy  String?  @map("changed_by")
  createdAt  DateTime @default(now()) @map("created_at")
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt(sort: Desc)])
  @@map("post_updates")
}

model PostCitation {
  id          String   @id @default(uuid()) @db.Uuid
  postId      String   @db.Uuid @map("post_id")
  sourceName  String   @map("source_name")
  sourceUrl   String   @map("source_url")
  sourceTitle String   @map("source_title")
  quotedClaim String?  @map("quoted_claim")
  createdAt   DateTime @default(now()) @map("created_at")
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([sourceUrl])
  @@map("post_citations")
}

model FeaturedFounderRequest {
  id                    String                @id @default(uuid()) @db.Uuid
  founderName            String                @map("founder_name")
  workEmail              String                @map("work_email")
  companyName            String                @map("company_name")
  websiteUrl             String?               @map("website_url")
  linkedinUrl            String?               @map("linkedin_url")
  country                String?
  industry               String?
  stage                  String?
  productSummary         String                @map("product_summary")
  fundingInfo            String?               @map("funding_info")
  plan                   FeaturedPlan
  priceInr               Int                   @map("price_inr")
  priceUsd               Int                   @map("price_usd")
  source                 String                @default("n8n_embed")
  externalSubmissionId   String?               @unique @map("external_submission_id")
  status                 FeaturedRequestStatus @default(NEW)
  reviewNotes            String?               @map("review_notes")
  publishedFounderEntryId String?              @map("published_founder_entry_id")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  interviewSubmissions   InterviewQuestionnaireSubmission[]

  @@index([status, createdAt(sort: Desc)])
  @@index([workEmail])
  @@index([companyName])
  @@map("featured_founder_requests")
}

model InterviewQuestionnaireSubmission {
  id              String                 @id @default(uuid()) @db.Uuid
  featuredRequestId String?              @db.Uuid @map("featured_request_id")
  founderName      String                @map("founder_name")
  workEmail        String                @map("work_email")
  companyName      String                @map("company_name")
  responsesJson    Json                  @map("responses_json")
  assetLinksJson   Json?                 @map("asset_links_json")
  externalSubmissionId String?           @unique @map("external_submission_id")
  status           String                @default("new")
  source           String                @default("site_form")
  reviewNotes      String?               @map("review_notes")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  featuredRequest  FeaturedFounderRequest? @relation(fields: [featuredRequestId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([workEmail])
  @@index([companyName])
  @@index([featuredRequestId])
  @@map("interview_questionnaire_submissions")
}

model GuestPostOrder {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String
  workEmail            String   @map("work_email")
  companyName          String   @map("company_name")
  websiteUrl           String?  @map("website_url")
  targetUrl            String?  @map("target_url")
  topic                String
  brief                String
  budgetInr            Int?     @map("budget_inr")
  packageKey           String?  @map("package_key")
  source               String   @default("site_form")
  externalSubmissionId String?  @unique @map("external_submission_id")
  status               String   @default("new")
  reviewNotes          String?  @map("review_notes")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt(sort: Desc)])
  @@index([workEmail])
  @@index([companyName])
  @@map("guest_post_orders")
}

model InstagramPost {
  id             String   @id @default(uuid()) @db.Uuid
  externalPostId String   @unique @map("external_post_id")
  caption        String?
  mediaUrl       String   @map("media_url")
  permalink      String
  thumbnailUrl   String?  @map("thumbnail_url")
  postedAt       DateTime @map("posted_at")
  ingestedAt     DateTime @default(now()) @map("ingested_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([postedAt(sort: Desc)])
  @@map("instagram_posts")
}

model PricingWaitlistRequest {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  workEmail   String   @map("work_email")
  intent      String
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  source      String   @default("pricing_page")
  status      String   @default("new")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([createdAt(sort: Desc)])
  @@index([workEmail])
  @@map("pricing_waitlist_requests")
}

model SiteEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventName String   @map("event_name")
  path      String
  referrer  String?
  sessionId String?  @map("session_id")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventName, createdAt(sort: Desc)])
  @@index([path])
  @@map("site_events")
}
